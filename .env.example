# Copy this file to .env.local and fill in the values from your Supabase project

# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Found in: Supabase Dashboard → Project Settings → API → service_role (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Choose any password you want for the /admin upload page
ADMIN_PASSWORD=choose-a-strong-password-here
